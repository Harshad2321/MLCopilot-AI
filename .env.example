# MLCopilot AI — Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank to use local SQLite (default for dev)
# Set to a PostgreSQL URL for RDS in production:
# DATABASE_URL=postgresql://user:password@your-rds-endpoint:5432/mlcopilot
DATABASE_URL=

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Option 1: Amazon Bedrock (recommended — uses your AWS credits)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.titan-text-express-v1

# Option 2: OpenAI
OPENAI_API_KEY=

# Option 3: Anthropic
ANTHROPIC_API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the API
# Example: https://mlcopilot.yourdomain.com,http://localhost:3000
ALLOWED_ORIGINS=*
