{
    "name": "mlcopilot",
    "displayName": "MLCopilot",
    "description": "Real-Time ML Training Monitor – detect failures, get recommendations, fix training live.",
    "version": "0.1.0",
    "publisher": "mlcopilot",
    "engines": { "vscode": "^1.85.0" },
    "categories": ["Machine Learning", "Data Science", "Other"],
    "icon": "icon.png",
    "activationEvents": [],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "mlcopilot.start",
                "title": "MLCopilot: Start Training Monitor",
                "icon": "$(play)"
            },
            {
                "command": "mlcopilot.stop",
                "title": "MLCopilot: Stop Training Monitor",
                "icon": "$(debug-stop)"
            },
            {
                "command": "mlcopilot.openUI",
                "title": "MLCopilot: Open Dashboard",
                "icon": "$(link-external)"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "mlcopilot-sidebar",
                    "title": "MLCopilot",
                    "icon": "$(pulse)"
                }
            ]
        },
        "views": {
            "mlcopilot-sidebar": [
                {
                    "id": "mlcopilot.statusView",
                    "name": "Training Monitor",
                    "type": "webview"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "devDependencies": {
        "@types/vscode": "^1.85.0",
        "@types/node": "^20.0.0",
        "typescript": "^5.3.0"
    }
}
